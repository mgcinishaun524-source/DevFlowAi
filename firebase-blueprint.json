{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "githubUsername": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "projects": {
      "title": "Project",
      "description": "A developer project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "githubRepo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "tasks": {
      "title": "Task",
      "description": "A task within a project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "done"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "assigneeId": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "title", "status"]
    },
    "repositories": {
      "title": "Repository",
      "description": "Cached GitHub repository data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "owner": { "type": "string" },
        "name": { "type": "string" },
        "stars": { "type": "number" },
        "forks": { "type": "number" },
        "lastCommit": { "type": "string" },
        "activityData": { "type": "array", "items": { "type": "object" } }
      }
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "users",
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": "projects",
      "description": "Project metadata"
    },
    "/projects/{projectId}/tasks/{taskId}": {
      "schema": "tasks",
      "description": "Tasks belonging to a project"
    },
    "/repositories/{repoId}": {
      "schema": "repositories",
      "description": "GitHub repository cache"
    }
  }
}
